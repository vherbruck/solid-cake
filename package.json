{
  "name": "solid-cake",
  "version": "0.1.0",
  "description": "Composable chart primitives for SolidJS — inspired by Layer Cake",
  "type": "module",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "solidjs",
    "chart",
    "composable",
    "svg",
    "canvas",
    "d3",
    "layer-cake",
    "interactive",
    "drag",
    "visualization"
  ],
  "author": "vherbruck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vherbruck/solid-cake.git"
  },
  "homepage": "https://github.com/vherbruck/solid-cake",
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "^1.9.10",
    "tsup": "^8.5.1",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
